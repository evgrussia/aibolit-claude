{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "aibolit-backend",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "web.backend.main:app", "--reload", "--port", "8007"],
      "port": 8007
    },
    {
      "name": "aibolit-frontend",
      "runtimeExecutable": "cmd.exe",
      "runtimeArgs": ["/c", "npm.cmd", "run", "dev", "--prefix", "web/frontend"],
      "port": 5173,
      "autoPort": true
    }
  ]
}
