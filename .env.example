# Aibolit AI — Environment Variables
# Copy to .env and fill in values

# PostgreSQL connection
DATABASE_URL=postgresql://aibolit:aibolit@localhost:5432/aibolit
POSTGRES_PASSWORD=aibolit

# JWT secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
AIBOLIT_SECRET_KEY=

# Encryption key for medical data at rest (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
AIBOLIT_ENCRYPTION_KEY=

# Claude Code CLI auth token
CLAUDE_CODE_OAUTH_TOKEN=

# WHO ICD-11 API credentials (optional, falls back to local ICD-10)
WHO_ICD_CLIENT_ID=
WHO_ICD_CLIENT_SECRET=
